-- LOD (Level of Detail) settings for performance
local RENDER_DISTANCE     = 150  -- Full visibility range
local FAR_DISTANCE        = 300  -- Reduced visibility range
local FADE_DISTANCE       = 50   -- Distance to start fade-in
local MIN_ORB_SIZE        = 0.3  -- Minimum orb size when far
local MAX_ORB_SIZE        = 2.0  -- Full orb size
local LOD_UPDATE_RATE     = 0.1  -- How often to update LOD (seconds)

