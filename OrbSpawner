		local localPlayer = Players.LocalPlayer
		if localPlayer then
			local mode = localPlayer:GetAttribute("GraphicsMode") or "High"
			print("[OrbSpawner] Current graphics mode:", mode)
			return mode
		end
	end
	return "High"
end

