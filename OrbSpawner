local OrbSpawner = {
	spawnDeathOrbsForSnake = spawnDeathOrbsForSnake,
	createSafeOrb = createSafeOrb,
	-- New exports for LOD control
	setRenderDistance = function(dist) RENDER_DISTANCE = dist end,
	setFadeDistance = function(dist) FADE_DISTANCE = dist end,
	-- Graphics mode control
	setGraphicsMode = function(mode)
		if RunService:IsClient() then
			local SetGraphicsModeEvent = ReplicatedStorage:FindFirstChild("SetGraphicsMode")
			if SetGraphicsModeEvent then
				SetGraphicsModeEvent:FireServer(mode)
			end
		end
	end
}

_G.OrbSpawner = OrbSpawner
print("OrbSpawner loaded successfully - EXTREME GRAPHICS MODE SUPPORT ADDED!")

return OrbSpawner
