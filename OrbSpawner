-- Utility: get all player heads
---------------------------------------------------------------------
local function getPlayerHeads()
	local heads = {}
	for _, p in Players:GetPlayers() do
		local root = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
		if root then table.insert(heads, {player = p, part = root}) end
	end
	return heads
end

---------------------------------------------------------------------
-- Get all viewing positions (players + AI snakes)
---------------------------------------------------------------------
local function getAllViewingPositions()
	local positions = {}

	-- Player positions
	for _, p in Players:GetPlayers() do
		local root = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
		if root then table.insert(positions, root.Position) end
	end

	-- AI snake positions
	local ASM = getAISnakeModule()
	if ASM and ASM._activeSnakes then
		for _, s in ASM._activeSnakes do
			if s.HeadParts and s.HeadParts.head then
				table.insert(positions, s.HeadParts.head.Position)
			end
		end
	end

	return positions
end

---------------------------------------------------------------------
-- LOD system: Calculate orb visibility state
---------------------------------------------------------------------
local function calculateOrbLOD(orb, viewPositions)
	if not orb or not orb.Parent then return "hidden" end

	local orbPos = orb.Position
	local closestDist = math.huge

	for _, viewPos in viewPositions do
		local dist = (orbPos - viewPos).Magnitude
		if dist < closestDist then closestDist = dist end
	end

	if closestDist <= FADE_DISTANCE then
		return "full", 1.0  -- Full visibility
	elseif closestDist <= RENDER_DISTANCE then
		-- Fade based on distance
		local fade = 1 - ((closestDist - FADE_DISTANCE) / (RENDER_DISTANCE - FADE_DISTANCE))
		return "fading", fade
	elseif closestDist <= FAR_DISTANCE then
		return "far", 0.3  -- Minimal visibility
	else
		return "hidden", 0  -- Too far, hide completely
	end
end

---------------------------------------------------------------------
-- Apply LOD state to orb with smooth transitions
---------------------------------------------------------------------
local function applyOrbLOD(orb, state, fadeValue)
	if not orb or not orb.Parent then return end

	local currentState = orbStates[orb] or {state = "hidden", fade = 0}
	local mode = RunService:IsClient() and getPlayerGraphicsMode() or "High"

	-- Skip if state hasn't changed significantly
	if currentState.state == state and math.abs(currentState.fade - fadeValue) < 0.1 then
		return
	end

	orbStates[orb] = {state = state, fade = fadeValue}

	-- Cancel existing tween
	if orbTweens[orb] then
		orbTweens[orb]:Cancel()
		orbTweens[orb] = nil
	end

	-- EXTREME SIZE AND TRANSPARENCY DIFFERENCES
	local sizeMultiplier = 1
	local transparencyOffset = 0
	
	if mode == "Low" then
		sizeMultiplier = 0.7  -- Smaller orbs in low mode
		transparencyOffset = 0.3  -- More transparent
	elseif mode == "Medium" then
		sizeMultiplier = 0.85
		transparencyOffset = 0.1
	end

	local targetSize = Vector3.new(1,1,1) * (MIN_ORB_SIZE + (MAX_ORB_SIZE - MIN_ORB_SIZE) * fadeValue) * sizeMultiplier
	local targetTransparency = transparencyOffset + (1 - transparencyOffset) * (1 - fadeValue)

	-- Apply based on state
	if state == "hidden" then
		orb.Transparency = 1
		orb.Size = Vector3.new(0.1, 0.1, 0.1)
		local light = orb:FindFirstChild("PointLight")
		if light then light.Enabled = false end
	else
		-- EXTREME LIGHT HANDLING
		local light = orb:FindFirstChild("PointLight")
		if light then 
			if RunService:IsClient() then
				if mode == "Low" then
					-- NO LIGHTS IN LOW MODE - EXTREME PERFORMANCE
					light:Destroy()
				elseif mode == "Medium" then
					-- REDUCED LIGHTS
					light.Enabled = fadeValue > 0.3  -- Only enable for closer orbs
					light.Brightness = 1 * fadeValue
					light.Range = 4 * fadeValue
					light.Shadows = false
				else -- High
					-- FULL LIGHTS
					light.Enabled = fadeValue > 0.1
					light.Brightness = 2 * fadeValue
					light.Range = 8 * fadeValue
					light.Shadows = false  -- Still no shadows for performance
				end
			else
				-- Server always uses full lights
				light.Enabled = fadeValue > 0.1
				light.Brightness = 2 * fadeValue
				light.Range = 8 * fadeValue
			end
		end

		-- EXTREME ANIMATION DIFFERENCES
		if RunService:IsClient() then
			if mode == "Low" then
				-- NO ANIMATIONS AT ALL - INSTANT CHANGES
				orb.Size = targetSize
				orb.Transparency = targetTransparency
			elseif mode == "Medium" then
				-- FAST SIMPLE ANIMATIONS
				local tween = TweenService:Create(orb, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
					Size = targetSize,
					Transparency = targetTransparency
				})
				orbTweens[orb] = tween
				tween:Play()
			else -- High
				-- FULL SMOOTH ANIMATIONS
				local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
				local tween = TweenService:Create(orb, tweenInfo, {
					Size = targetSize,
					Transparency = targetTransparency
				})
				orbTweens[orb] = tween
				tween:Play()

				-- Pop effect only in high mode
				if currentState.state == "hidden" and state ~= "hidden" then
					orb.Size = Vector3.new(0.1, 0.1, 0.1)
					local popTween = TweenService:Create(orb, 
						TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), 
						{Size = targetSize}
					)
					orbTweens[orb] = popTween
					popTween:Play()
				end
			end
		else
			-- Server always does full animations
			local tween = TweenService:Create(orb, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = targetSize,
				Transparency = targetTransparency
			})
			orbTweens[orb] = tween
			tween:Play()
		end
	end
end

---------------------------------------------------------------------
-- Growth / upgrade helpers  (all use getAISnakeModule)
---------------------------------------------------------------------
local function growAISnake(head, value)
	local ASM = getAISnakeModule()
	if not ASM or not ASM._activeSnakes then return end
	for _, s in ASM._activeSnakes do
		if s.HeadParts and s.HeadParts.head == head and s.grow then
			s:grow(value or 10)
		end
	end
end

local function giveUpgradeToAISnake(head)
	local ASM = getAISnakeModule()
	if not ASM or not ASM._activeSnakes then return end
	for _, s in ASM._activeSnakes do
		if s.HeadParts and s.HeadParts.head == head then
			SnakeUpgrades.GiveUpgrade(s)
		end
	end
end

local function growPlayerSnake(player, value)
	if not player or not player.Character then return end
	local snakeInst = _G.PlayerSnakes and _G.PlayerSnakes[player]
	if not snakeInst and player.Character:FindFirstChild("__SnakeInstance") then
		snakeInst = player.Character.__SnakeInstance.Value
	end
	if snakeInst and snakeInst.grow then snakeInst.grow(value or 10) end
end

local function giveUpgradeToPlayerSnake(player)
	local snakeInst = _G.PlayerSnakes and _G.PlayerSnakes[player]
	if snakeInst then SnakeUpgrades.GiveUpgrade(snakeInst) end
end

