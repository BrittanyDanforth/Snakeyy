---------------------------------------------------------------------
-- Dynamic spawn area
---------------------------------------------------------------------
local function getOrbSpawnArea()
	local groundPart = Workspace:FindFirstChild("SlitherIOGround")
	if groundPart and groundPart:IsA("BasePart") then
		local size, pos = groundPart.Size, groundPart.Position
		local hx, hz    = size.X / 2, size.Z / 2
		return {
			minX = math.floor(pos.X - hx) + 5, maxX = math.ceil(pos.X + hx) - 5,
			minZ = math.floor(pos.Z - hz) + 5, maxZ = math.ceil(pos.Z + hz) - 5,
			y    = pos.Y + size.Y / 2 + 1
		}
	end
	return {minX = -600, maxX = 150, minZ = -600, maxZ = 600, y = 4}
end

