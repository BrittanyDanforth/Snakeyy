---------------------------------------------------------------------
-- Safe orb creation (no attachments/constraints) - Now starts hidden
---------------------------------------------------------------------
local function createSafeOrb(position, value, name, color, material)
	local orb = Instance.new("Part")
	orb.Name = name or "Orb"
	orb.Shape = Enum.PartType.Ball
	orb.Size = Vector3.new(0.1, 0.1, 0.1)  -- Start tiny
	orb.Anchored = true
	orb.CanCollide = false
	orb.Color = color or Color3.new(1, 1, 0)
	orb.Position = position
	orb.TopSurface = Enum.SurfaceType.Smooth
	orb.BottomSurface = Enum.SurfaceType.Smooth
	orb.Transparency = 1  -- Start invisible
	
	-- Server always creates standard orbs
	orb.Material = material or Enum.Material.Neon
	orb.CastShadow = true
	
	orb.Parent = Workspace

	local val = Instance.new("NumberValue")
	val.Name = "Value"
	val.Value = value or 10
	val.Parent = orb

	-- EXTREME LIGHT HANDLING
	if RunService:IsServer() then
		-- Server always creates lights
		local light = Instance.new("PointLight")
		light.Parent = orb
		light.Color = orb.Color
		light.Brightness = 0
		light.Range = 0
		light.Enabled = false
		light.Shadows = true  -- Server has shadows
	elseif getPlayerGraphicsMode() ~= "Low" then
		-- Client only creates lights for Medium/High
		local light = Instance.new("PointLight")
		light.Parent = orb
		light.Color = orb.Color
		light.Brightness = 0
		light.Range = 0
		light.Enabled = false
		light.Shadows = false  -- No shadows on client
	end
	-- LOW MODE GETS NO LIGHTS AT ALL!

	-- Initialize as hidden
	orbStates[orb] = {state = "hidden", fade = 0}

	return orb
end

---------------------------------------------------------------------
-- Death-orb burst - FIXED: No attachments
---------------------------------------------------------------------
local function spawnDeathOrbs(pos, count)
	local spawned = {}
	for i = 1, count do
		local angle, dist = math.random() * math.pi * 2, math.random(3, 8)
		local off = Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
		local orb = createSafeOrb(pos + off, 10, "DeathOrb", Color3.fromRGB(255, 100, 100))
		table.insert(orbs, orb)
		table.insert(spawned, orb)
		attachOrbTouched(orb)

		-- Death orbs should be immediately visible where they spawn
		applyOrbLOD(orb, "full", 1.0)
	end
	return spawned
end

---------------------------------------------------------------------
-- Remove orb from tables
---------------------------------------------------------------------
local function removeOrb(orb)
	OrbUtils.removeOrb(orb)
	for i = #upgradeOrbs, 1, -1 do 
		if upgradeOrbs[i] == orb then 
			table.remove(upgradeOrbs, i) 
		end 
	end
	orbDebounce[orb] = nil
	orbStates[orb] = nil
	if orbTweens[orb] then
		orbTweens[orb]:Cancel()
		orbTweens[orb] = nil
	end
end

---------------------------------------------------------------------
-- Head identification helpers (players / AI)
---------------------------------------------------------------------
local function getPlayerFromTouchedPart(part)
	for _, h in getPlayerHeads() do
		if h.part == part then return h.player end
	end
	return nil
end

local function isPartAISnakeHead(part)
	if part.Name == "AISnakeHead" then return part end
	if part.Parent then
		local head = part.Parent:FindFirstChild("AISnakeHead")
		if head then return head end
	end
	return nil
end

local function getAISnakeHeadFromPart(part)
	local simple = isPartAISnakeHead(part)
	if simple then return simple end

	local ASM = getAISnakeModule()
	if not ASM or not ASM._activeSnakes then return nil end

	for _, s in ASM._activeSnakes do
		local head = s.HeadParts and s.HeadParts.head
		if head and (part == head or (head.Parent and part:IsDescendantOf(head.Parent))) then
			return head
		end
	end
	return nil
end

---------------------------------------------------------------------
-- Atomic orb collection - FIXED: Safe remote event firing
---------------------------------------------------------------------
local function atomicCollectOrb(orb, collType, collObj)
	if not orb or not orb.Parent or orbDebounce[orb] then return end
	orbDebounce[orb] = true

	createOrbCollectVFX(orb.Position, orb.Color)

	if collType == "player" then
		local p = collObj
		-- FIXED: Only fire remote event if it exists and player is valid
		if OrbCollectedEvent and p and p:IsA("Player") then
			-- Use pcall to prevent errors if client doesn't handle it
			pcall(function()
				OrbCollectedEvent:FireClient(p, orb.Position, orb.Name)
			end)
		end
		if orb.Name == "UpgradeOrb" then
			giveUpgradeToPlayerSnake(p)
		else
			local val = (orb:FindFirstChild("Value") and orb.Value.Value) or 10
			growPlayerSnake(p, val)
		end
	else -- "ai"
		local head = collObj
		if orb.Name == "UpgradeOrb" then
			giveUpgradeToAISnake(head)
		else
			local val = (orb:FindFirstChild("Value") and orb.Value.Value) or 10
			growAISnake(head, val)
		end
	end

	removeOrb(orb)
	if orb and orb.Parent then 
		pcall(function() orb:Destroy() end) 
	end
end

---------------------------------------------------------------------
-- Attach .Touched listener
---------------------------------------------------------------------
function attachOrbTouched(orb)
	orb.Touched:Connect(function(hit)
		if not orb or not orb.Parent or orbDebounce[orb] then return end

		local player = getPlayerFromTouchedPart(hit)
		if player then
			atomicCollectOrb(orb, "player", player)
			return
		end

		local aiHead = getAISnakeHeadFromPart(hit)
		if aiHead then
			atomicCollectOrb(orb, "ai", aiHead)
			return
		end
		orbDebounce[orb] = nil
	end)
end

---------------------------------------------------------------------
-- LOD Update Loop - Updates visibility of all orbs
---------------------------------------------------------------------
local lastLODUpdate = 0
task.spawn(function()
	RunService.Heartbeat:Connect(function()
		local now = tick()
		
		-- EXTREME: Update less frequently in low mode
		local mode = RunService:IsClient() and getPlayerGraphicsMode() or "High"
		local updateRate = mode == "Low" and 0.5 or LOD_UPDATE_RATE
		
		if now - lastLODUpdate < updateRate then return end
		lastLODUpdate = now

		local viewPositions = getAllViewingPositions()
		if #viewPositions == 0 then return end

		-- EXTREME: Skip some orbs in low mode for performance
		local skipRate = mode == "Low" and 2 or 1

		-- Update LOD for all orbs
		for i = 1, #orbs, skipRate do
			local orb = orbs[i]
			if orb and orb.Parent then
				local state, fade = calculateOrbLOD(orb, viewPositions)
				applyOrbLOD(orb, state, fade)
			end
		end
	end)
end)

---------------------------------------------------------------------
-- Backup proximity scan (runs every 0.2 s) - only for visible orbs
---------------------------------------------------------------------
task.spawn(function()
	while true do 
		task.wait(0.2)
		local aiHeads = {}
		for _, obj in Workspace:GetDescendants() do
			if obj:IsA("BasePart") and obj.Name == "AISnakeHead" then
				aiHeads[#aiHeads + 1] = obj
			end
		end
		local players = getPlayerHeads()

		for i = #orbs, 1, -1 do
			local orb = orbs[i]
			local orbState = orbStates[orb]
			-- Only check visible orbs
			if orb and orb.Parent and not orbDebounce[orb] and orbState and orbState.state ~= "hidden" then
				for _, h in aiHeads do
					if (h.Position - orb.Position).Magnitude < 5 then
						atomicCollectOrb(orb, "ai", h)
						break
					end
				end
				for _, ph in players do
					if orb and orb.Parent and (ph.part.Position - orb.Position).Magnitude < 5 then
						atomicCollectOrb(orb, "player", ph.player)
						break
					end
				end
			end
		end
	end
end)

---------------------------------------------------------------------
-- Orb spawning helpers
---------------------------------------------------------------------
local function randomPosition()
	local a = getOrbSpawnArea()
	return Vector3.new(math.random(a.minX, a.maxX), a.y, math.random(a.minZ, a.maxZ))
end

local function createOrb()
	local orb
	if math.random() < UPGRADE_ORB_CHANCE then
		orb = createSafeOrb(randomPosition(), 0, "UpgradeOrb",
			Color3.fromRGB(0, 200, 255), Enum.Material.ForceField)
		upgradeOrbs[#upgradeOrbs + 1] = orb
		orbs[#orbs + 1] = orb
	else
		orb = OrbUtils.spawnOrbAt(randomPosition(), 10)
		if orb then
			-- Make sure new orbs from OrbUtils also start hidden
			orb.Transparency = 1
			orb.Size = Vector3.new(0.1, 0.1, 0.1)
			orbStates[orb] = {state = "hidden", fade = 0}
			local light = orb:FindFirstChild("PointLight")
			if light then light.Enabled = false end
		end
	end
	if orb then attachOrbTouched(orb) end
	return orb
end

---------------------------------------------------------------------
-- Death-orb entry point (for AISnake:Destroy)
---------------------------------------------------------------------
local function spawnDeathOrbsForSnake(pos, segCount)
	return spawnDeathOrbs(pos, math.min(segCount, 50))
end

